# Required for authenticated application runs. Generate a long random value.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256

# Leave empty only when running unit tests that mock the model service.
DASHSCOPE_API_KEY=
# OpenAI-compatible text endpoint and synchronous image endpoint. Keep the
# connection timeout short; the text read timeout allows one controlled response.
DASHSCOPE_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_TEXT_MODEL=qwen3.7-plus
DASHSCOPE_TEXT_REASONING_EFFORT=none
DASHSCOPE_IMAGE_MODEL=wan2.6-t2i
DASHSCOPE_IMAGE_SIZE=1280*1280
DASHSCOPE_TEXT_CONNECT_TIMEOUT_SECONDS=5
DASHSCOPE_TEXT_READ_TIMEOUT_SECONDS=120
DASHSCOPE_IMAGE_CONNECT_TIMEOUT_SECONDS=5
DASHSCOPE_IMAGE_READ_TIMEOUT_SECONDS=30

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=aigc_platform
MYSQL_CONNECT_TIMEOUT_SECONDS=5
MYSQL_READ_TIMEOUT_SECONDS=10
MYSQL_WRITE_TIMEOUT_SECONDS=10

# Disabled by default. The controlled real-business smoke runner accepts only
# aigc_platform_demo and this local test identity. Never commit its password.
RUN_REAL_BUSINESS_SMOKE=0
SMOKE_TEST_USERNAME=
SMOKE_TEST_PASSWORD=

HIVE_HOST=localhost
HIVE_PORT=10000
HIVE_USERNAME=mywork
HIVE_DATABASE=aigc_platform

ADMIN_CREATION_KEY=
